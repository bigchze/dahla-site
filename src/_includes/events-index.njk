---
layout: base.njk
---
<section class="block">
  <div class="container">
    <div class="prose">{{ content | safe }}</div>

    <h2>{{ meetings_title or "DAHLA Meetings & Board Events" }}</h2>
    {% if meetings and meetings.length > 0 %}
    <div class="event-list" style="margin-bottom:36px;">
      {% for m in meetings %}
        <div class="event-card">
          <span class="event-date">{{ m.date }}</span>
          <h3>{{ m.title }}</h3>
          {% if m.location %}<p style="margin-bottom:6px;color:var(--muted);">{{ m.location }}</p>{% endif %}
          {% if m.notes %}<p style="margin-bottom:0;">{{ m.notes }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="callout" style="margin:24px 0 36px;">
      <p style="margin-bottom:0;">{{ meetings_note or "Meeting dates will be posted here as they're confirmed." }}</p>
    </div>
    {% endif %}

    <h2>Upcoming &amp; Annual Events</h2>
    <div class="event-list">
      {% for event in collections.events | reverse %}
        <div class="event-card">
          <span class="event-date">{{ event.data.event_date }}</span>
          <h3><a href="{{ event.url }}">{{ event.data.title }}</a></h3>
          {% if event.data.location %}<p style="margin-bottom:6px;color:var(--muted);">{{ event.data.location }}</p>{% endif %}
          <p style="margin-bottom:0;">{{ event.data.summary }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
